SQLITE_DB_PATH=data/ranking.db

# Fetch all characters with level >= RANKING_MIN_LEVEL (~5500 at Lv225+)
RANKING_MIN_LEVEL=225
RANKING_MAX_PAGES=800
RANKING_REQUEST_DELAY_SEC=0.35

SNAPSHOT_RETENTION_DAYS=35
MVP_HISTORY_DAYS=35

BENCHMARK_CHARACTER_NAME=pachimi
MVP_EXPORT_TOP_N=0
MVP_JSON_OUTPUT_PATH=../web/public/data/rankings.json
PAGES_SITE_URL=https://lulumi-tools.com

# Navigator API (worldId: Ain / Errai / Fang)
NAVIGATOR_REQUEST_DELAY_SEC=0.35
NAVIGATOR_FETCH_ENABLED=true
# Daily server rotation: Fang -> Errai -> Ain (one cohort per run)
NAVIGATOR_ROTATION_ENABLED=true
NAVIGATOR_ROTATION_EPOCH=2026-06-12

# Skip ranking + Navigator when today's snapshot is already in DB (default: on)
SKIP_RUN_IF_RANKING_DAY_EXISTS=true
# Skip deploy when fetch skipped (CI push sets false → export + deploy only)
# SKIP_DEPLOY_IF_DAY_CAPTURED=true
# FORCE_RANKING_FETCH=true
